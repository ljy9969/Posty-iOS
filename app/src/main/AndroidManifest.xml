<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- 마감일 알림 표시 (Android 13+ 런타임 권한). -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <!-- 정시 알람 — 마감 당일 아침 알림. 미허용 시 비정시 알람으로 자동 fallback. -->
    <uses-permission android:name="android.permission.SCHEDULE_EXACT_ALARM" />
    <!-- 재부팅 후 알림 재예약. -->
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />

    <application
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.Posty">

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:theme="@style/Theme.Posty.Starting">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <receiver
            android:name=".widget.PostyWidgetProvider"
            android:exported="false">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/posty_widget_info" />
        </receiver>

        <!-- 위젯 리스트(여러 장) 데이터 공급 서비스. -->
        <service
            android:name=".widget.PostyWidgetService"
            android:permission="android.permission.BIND_REMOTEVIEWS"
            android:exported="false" />

        <!-- 마감 알림 발화 리시버. -->
        <receiver
            android:name=".reminder.ReminderReceiver"
            android:exported="false" />

        <!-- 재부팅 후 알림 재예약. -->
        <receiver
            android:name=".reminder.BootReceiver"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.BOOT_COMPLETED" />
            </intent-filter>
        </receiver>
    </application>

</manifest>
